#!/bin/bash
# xsel shim: Forwards clipboard operations to the host Mac via clipboard server.
# Handles the flags that Node.js clipboard libraries use:
#   xsel --clipboard --input     (copy, reads stdin)
#   xsel --clipboard --output    (paste, writes to stdout)

PORT="${CLAUDE_CLIPBOARD_PORT:-21564}"
HOST="host.docker.internal"

paste=false
for arg in "$@"; do
    if [ "$arg" = "--output" ] || [ "$arg" = "-o" ]; then
        paste=true
    fi
done

TOKEN_HEADER="X-Clauded-Token: ${CLAUDED_BRIDGE_TOKEN:-}"
if $paste; then
    curl -sf -H "$TOKEN_HEADER" "http://${HOST}:${PORT}/paste" 2>/dev/null
else
    curl -sf -X POST -H "$TOKEN_HEADER" --data-binary @- "http://${HOST}:${PORT}/copy" >/dev/null 2>&1
fi
